# Supabase config for the static SPA. Only VITE_-prefixed vars are exposed to
# the client and inlined into the build. These are the Supabase publishable
# (anon) key + project URL — they are safe to expose publicly because access is
# enforced by Row-Level Security in Supabase. Copy this file to `.env` and fill in.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=
